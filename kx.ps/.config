# =============================================================================
#  .config  —  Non-secret environment configuration
#  ~/dev/pwsh-env/.config
#  Safe to version control. No secrets here.
# =============================================================================

[editor]
default         = nvim
git_editor      = nvim
diff_tool       = nvim -d

[shell]
profile_path    = ~/Documents/PowerShell/Microsoft.PowerShell_profile.ps1
config_dir      = ~/dev/pwsh-env
secrets_file    = ~/dev/pwsh-env/.env.encrypted
cheatsheet_file = ~/dev/pwsh-env/CHEATSHEET.md
history_file    = ~/dev/pwsh-env/.repl_history

[aws]
default_profile = default
default_region  = us-east-1
output_format   = json

[gcp]
default_project = my-project
default_region  = us-central1
default_zone    = us-central1-a

[azure]
default_subscription =
default_location     = eastus

[ai]
default_model_claude  = claude-opus-4-5
default_model_gemini  = gemini-pro
default_model_grok    = grok-beta
max_tokens            = 1024
cheatsheet_model      = claude-opus-4-5

[git]
default_branch  = main
gpg_sign        = false
auto_fetch      = true

[node]
package_manager = npm
default_registry = https://registry.npmjs.org

[python]
package_manager = uv
default_python  = 3.12

[intellij]
toolbox_path    = ~/AppData/Local/JetBrains/Toolbox/apps

[paths]
dev_root        = ~/dev
projects_root   = ~/projects
downloads       = ~/Downloads
